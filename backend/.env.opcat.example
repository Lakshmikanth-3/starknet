# OP_CAT Covenant Configuration Example
# Copy this to .env and fill in the values after running setup_covenant.js

# ══════════════════════════════════════════════════════════════
#  SECURITY WARNING
# ══════════════════════════════════════════════════════════════
# Keep these values secret. SEQUENCER_SIGNING_KEY controls the
# ability to authorize Bitcoin withdrawals via covenant proofs.
# ══════════════════════════════════════════════════════════════

# Covenant Bridge Configuration
# ------------------------------
# Enable OP_CAT covenant mode for trustless withdrawals
USE_OPCAT_COVENANTS=false

# The Bitcoin address with OP_CAT covenant script
# Generated by: node scripts/setup_covenant.js
COVENANT_ADDRESS=tb1p...

# Hex-encoded covenant script that validates Starknet proofs
COVENANT_SCRIPT_HEX=

# Merkle root for taproot script tree
COVENANT_MERKLE_ROOT=

# Sequencer Keys
# --------------
# Private key for signing Starknet burn proofs (secp256k1)
SEQUENCER_SIGNING_KEY=

# Public key corresponding to SEQUENCER_SIGNING_KEY
# This is embedded in the covenant script
SEQUENCER_PUBLIC_KEY=

# Network Configuration
# ---------------------
# Mempool API for OP_CAT signet
OPCAT_MEMPOOL_API=https://mempool.space/signet/api

# Withdrawal Processor Settings
# ------------------------------
# How often to check for pending withdrawals (milliseconds)
WITHDRAWAL_PROCESSOR_INTERVAL_MS=30000

# Minimum Starknet confirmations before processing withdrawal
WITHDRAWAL_MIN_CONFIRMATIONS=1

# ══════════════════════════════════════════════════════════════
#  SETUP INSTRUCTIONS
# ══════════════════════════════════════════════════════════════
#
# 1. Run setup script:
#    node backend/scripts/setup_covenant.js
#
# 2. Copy generated values to .env:
#    - COVENANT_ADDRESS
#    - COVENANT_SCRIPT_HEX  
#    - COVENANT_MERKLE_ROOT
#    - SEQUENCER_SIGNING_KEY
#    - SEQUENCER_PUBLIC_KEY
#
# 3. Fund the covenant address with OP_CAT signet BTC:
#    - Get coins from: https://signet.bc-2.jp/
#    - Send to: bitcoin-cli -signet sendtoaddress $COVENANT_ADDRESS 0.01
#
# 4. Enable covenant mode:
#    - Set USE_OPCAT_COVENANTS=true
#
# 5. Restart backend:
#    npm run dev
#
# 6. Test withdrawal:
#    node backend/scripts/test_covenant_withdrawal.js
#
# ══════════════════════════════════════════════════════════════
#  HOW IT WORKS
# ══════════════════════════════════════════════════════════════
#
# Traditional Mode (USE_OPCAT_COVENANTS=false):
# - Operator's private key directly controls Bitcoin
# - Application-layer authorization checks only
# - Operator can bypass by running bitcoin-cli manually
# - TRUST REQUIRED
#
# Covenant Mode (USE_OPCAT_COVENANTS=true):
# - Bitcoin locked in covenant script
# - Withdrawals require valid Starknet burn proof
# - OP_CAT verifies proof cryptographically on-chain
# - Proof contains: tx_hash, amount, nullifier, recipient, block
# - Even operator cannot withdraw without Starknet burn
# - TRUSTLESS
#
# ══════════════════════════════════════════════════════════════

# Development Settings (for testing)
# -----------------------------------
# Override network for testing on regular signet/testnet
# BITCOIN_NETWORK=signet

# Mock covenant for development (no real OP_CAT required)
# DEV_MODE=true
